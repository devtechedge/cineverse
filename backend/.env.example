# Cineverse backend — environment variables
# Copy to `.env` and adjust for your environment.

APP_ENV=dev                       # dev | staging | prod | test
DEBUG=true
FRONTEND_ORIGIN=http://localhost:3000

# Security — change in production!
SECRET_KEY=replace-with-64-byte-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Database
DATABASE_URL=postgresql+asyncpg://cineverse:cineverse@db:5432/cineverse
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0

# Storage
STORAGE_BACKEND=local             # local | s3
STORAGE_ROOT=/data/cineverse
# For S3:
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Uploads
MAX_UPLOAD_BYTES=10737418240      # 10 GiB
CHUNK_SIZE_BYTES=1048576          # 1 MiB

# FFmpeg
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
HLS_SEGMENT_SECONDS=4

# Observability
LOG_LEVEL=INFO
LOG_JSON=true
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
